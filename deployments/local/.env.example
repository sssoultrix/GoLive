## Local environment for deployments/local/docker-compose.yml
## Copy to .env and adjust if needed.

# Shared
JWT_SECRET_KEY=dev_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Kafka topic/group
KAFKA_TOPIC_USER_EVENTS=user.events.v1
KAFKA_GROUP_PROFILE=profile-service

# Optional direct HTTP fallback (usually leave empty when using events)
PROFILE_BASE_URL=

# Host ports (set if you have conflicts)
AUTH_HTTP_PORT_HOST=8080
PROFILE_HTTP_PORT_HOST=8082
AUTH_POSTGRES_PORT_HOST=5432
PROFILE_POSTGRES_PORT_HOST=5433

# Auth Postgres
AUTH_POSTGRES_DB=auth
AUTH_POSTGRES_USER=auth
AUTH_POSTGRES_PASSWORD=auth
AUTH_POSTGRES_SSLMODE=disable

# Profile Postgres
PROFILE_POSTGRES_DB=profile
PROFILE_POSTGRES_USER=profile
PROFILE_POSTGRES_PASSWORD=profile
PROFILE_POSTGRES_SSLMODE=disable

