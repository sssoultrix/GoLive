## Auth service
AUTH_HTTP_ADDR=0.0.0.0:8080
AUTH_LOG_LEVEL=info

## Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_SSLMODE=disable

## JWT
JWT_SECRET_KEY=change_me_please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

## Agent (service-to-service / internal auth)
AGENT_SECRET_KEY=change_me_please

